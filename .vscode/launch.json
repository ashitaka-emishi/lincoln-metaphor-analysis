{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Pipeline Status",
      "program": "${workspaceFolder}/scripts/pipeline_status.js",
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Validate Schema",
      "program": "${workspaceFolder}/scripts/validate_schema.js",
      "console": "integratedTerminal"
