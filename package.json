{
  "name": "lincoln-metaphor",
  "version": "1.0.0",
  "description": "Structured metaphor analysis of Lincoln's rhetoric, 1838-1865",
  "scripts": {
    "status": "node scripts/pipeline_status.js",
    "migrate:annotations": "node scripts/migrate_annotations_to_stage4.js",
    "validate": "node scripts/validate_schema.js && npm run validate:stage4m && npm run validate:source-provenance",
    "validate:annotation": "node scripts/validate_annotation_output.js",
    "validate:stage4m": "node scripts/stage4m/ingest-model-outputs.js --check",
    "validate:source-provenance": "node scripts/validate_source_provenance.js",
    "source:provenance": "node scripts/validate_source_provenance.js --write",
    "corpus:register": "node scripts/build_corpus_register.js",
    "evidence:chains": "node scripts/build_evidence_chains.js",
    "reliability:sample": "node scripts/build_reliability_sample.js",
    "reliability:results": "node scripts/build_reliability_results.js",
    "stage4m:ingest": "node scripts/stage4m/ingest-model-outputs.js",
    "variants:apparatus": "node scripts/build_textual_variant_apparatus.js",
    "benchmarks:registry": "python3 scripts/build_external_benchmark_registry.py",
    "reception:registry": "python3 scripts/build_reception_evidence_registry.py",
    "analysis:controlled": "node scripts/build_controlled_analysis.js",
    "audit:claims": "node scripts/build_claim_audit.js",
    "concordance": "node scripts/build_concordance.js",
    "analysis": "node scripts/run_analysis.js",
    "pipeline": "npm run validate && npm run concordance && npm run analysis && npm run evidence:chains && npm run reliability:sample && npm run reliability:results && npm run variants:apparatus && npm run analysis:controlled && npm run audit:claims",
    "freshness:generated": "node scripts/check_generated_freshness.js",
    "stage7": "python3 scripts/run_stage7.py",
    "stage7:large": "python3 scripts/run_stage7.py --dataset large",
    "stage7:download": "python3 scripts/download_lcc.py",
    "stage7:download:large": "python3 scripts/download_lcc.py --dataset large",
    "stage7:parse": "python3 scripts/parse_lcc.py --input data/lcc/en_small.xml --output data/lcc_subset/en_small.csv",
    "stage7:parse:large": "python3 scripts/parse_lcc.py --input data/lcc/en_large.xml --output data/lcc_subset/en_large.csv",
    "stage7:eval": "python3 scripts/evaluate_lcc.py --output reports/stage7/LCC_report.md",
    "site": "quarto render",
    "site:links": "python3 scripts/check_site_links.py --external",
    "site:preview": "quarto preview",
    "test": "node --test tests/*.test.js",
    "check:quarto": "quarto --version || (echo 'Quarto not found. Install from https://quarto.org/docs/get-started/ or: brew install quarto' && exit 1)"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  }
}
